{
  "manifest_version": 3,
  "name": "Claude Usage Meter",
  "version": "1.0.0",
  "description": "Shows your current Claude session usage and time until the limit resets in a floating button on claude.ai.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "unlimitedStorage", "alarms", "tabs", "notifications"],
  "host_permissions": ["https://claude.ai/*"],
  "background": { "service_worker": "src/background.js" },
  "options_page": "src/options.html",
  "action": {
    "default_title": "Claude Usage Meter",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["src/harvest.js", "src/inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": [
        "src/estimate.js",
        "src/log.js",
        "src/predict.js",
        "src/jobstore.js",
        "src/jobform.js",
        "src/content.js",
        "src/autocontinue.js",
        "src/scheduler-run.js"
      ],
      "css": ["src/content.css"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ]
}
